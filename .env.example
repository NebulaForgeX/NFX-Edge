# NFX-Edge environment variables example
# Usage:
# 1) cp .env.example .env
# 2) Edit values for your machine paths

# Domain placeholders
DASHBOARD_HOST=traefik.xxx.example.com
SITE1_DOMAIN=site1.example.com
SITE2_DOMAIN=site2.example.com

# Path placeholders
CERTS_DIR=/absolute/path/to/certificates
SITE1_WWW_DIR=./path/to/site1-www
SITE1_ADMIN_DIR=./path/to/site1-admin
SITE2_WWW_DIR=./path/to/site2-www
NGINX_CONFIG_FILE=./path/to/nginx.conf
